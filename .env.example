# ==================== 数据库配置 ====================
POSTGRES_USER=your_username_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=pekno_iris
DATA_DIR=./data

# ==================== Redis 配置 ====================
REDIS_URL=redis://127.0.0.1:6379
USE_REDIS=True

# ==================== 加密密钥配置 ====================
# 如果未显式提供以下密钥，Iris 会在首次启动时自动生成并写入 IRIS_SECRET_DIR。
# Hub 和 Worker 共用同一份密钥文件，确保加解密一致。
# 若需手动生成密钥，请运行: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IRIS_SECRET_DIR=./data/secrets
# IRIS_ENCRYPTION_KEY=your_fernet_key_here

# ==================== 日志配置 ====================
# 可选值: DEBUG, INFO, WARNING, ERROR
APP_ENV=dev
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=DEBUG
UVICORN_RELOAD=true
PEKNO_ACCELERATOR=cpu
EXECUTION_MODE=cpu
OLLAMA_BASE_URL=
# Override these only when using docker-compose.accel.cuda.yaml via scripts/compose.*
# APP_BASE_IMAGE=python:3.13-slim
# WORKER_BASE_IMAGE=python:3.13-slim
# CUDA_APP_BASE_IMAGE=nvidia/cuda:12.9.1-cudnn-runtime-ubuntu24.04
# CUDA_WORKER_BASE_IMAGE=nvidia/cuda:12.9.1-cudnn-runtime-ubuntu24.04
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ==================== 认证配置 ====================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT_SECRET_KEY 同样会自动生成并持久化到 IRIS_SECRET_DIR
