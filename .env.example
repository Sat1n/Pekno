# ==================== 数据库配置 ====================
POSTGRES_USER=natis
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=pekno_iris

# ==================== Redis 配置 ====================
REDIS_URL=redis://127.0.0.1:6379
USE_REDIS=True

# ==================== 加密密钥配置 ====================
# 注意：这个密钥必须保持一致，否则Worker无法解密Hub加密的数据
# 可以通过运行 python -c "from hub.core.crypto import generate_encryption_key; print(generate_encryption_key())" 生成新密钥
# 生成后将密钥替换下面的值
IRIS_ENCRYPTION_KEY=your_encryption_key_here

# ==================== 日志配置 ====================
# 可选值: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
