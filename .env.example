# ==================== 数据库配置 ====================
POSTGRES_USER=pekno
POSTGRES_PASSWORD=pekno_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=pekno
DATA_DIR=./data

# ==================== 预构建镜像配置 ====================
# 用 docker-compose.prod.yml 部署时会使用这些镜像参数。
# 如果你使用自己的 fork 或组织发布镜像，请把 owner 改成对应的 GHCR owner。
PEKNO_IMAGE_OWNER=sat1n
PEKNO_IMAGE_TAG=latest
PEKNO_HTTP_PORT=9080

# ==================== Redis 配置 ====================
REDIS_URL=redis://127.0.0.1:6379
USE_REDIS=True

# ==================== 加密密钥配置 ====================
# 如果未显式提供以下密钥，Pekno 会在首次启动时自动生成并写入 PEKNO_SECRET_DIR。
# Hub 和 Worker 共用同一份密钥文件，确保加解密一致。
# 若需手动生成密钥，请运行: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PEKNO_SECRET_DIR=./data/secrets
# PEKNO_ENCRYPTION_KEY=your_fernet_key_here

# ==================== 日志配置 ====================
# 可选值: DEBUG, INFO, WARNING, ERROR
APP_ENV=dev
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=DEBUG
UVICORN_RELOAD=true
WORKER_EXECUTION_MODE=cpu
OLLAMA_BASE_URL=
# For worker-side ML acceleration, uncomment the worker `extends` block in
# docker-compose.yaml and set the service in worker.ml.yml to `cuda` or `rocm`.
# Then change the base image and execution mode here.
# WORKER_BASE_IMAGE=python:3.13-slim
# CUDA example:
# WORKER_BASE_IMAGE=nvidia/cuda:12.9.1-cudnn-runtime-ubuntu24.04
# WORKER_EXECUTION_MODE=cuda
# ROCm example:
# WORKER_BASE_IMAGE=rocm/dev-ubuntu-24.04:6.4.1-complete
# WORKER_EXECUTION_MODE=rocm

# ==================== 认证配置 ====================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
# JWT_SECRET_KEY 同样会自动生成并持久化到 PEKNO_SECRET_DIR
# JWT_SECRET_KEY=your_jwt_secret_here
